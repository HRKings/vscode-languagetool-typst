// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "bun: watch",
			"type": "shell",
			"command": "bun",
			"args": ["run", "watch"],
			"problemMatcher": ["$ts-webpack-watch", "$tslint-webpack-watch"],
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "bun: test-compile",
			"type": "shell",
			"command": "bun",
			"args": ["run", "test-compile"],
			"problemMatcher": []
		},
		{
			"label": "bun: main-dist",
			"type": "shell",
			"command": "bun",
			"args": ["run", "main-dist"],
			"problemMatcher": []
		}
	]
}
