            "sk-SK",
            "sl-SI",
            "es",
            "sv",
            "tl-PH",
            "ta-IN",
            "uk-UA"
          ],
          "enumDescriptions": [
            "Auto Select",
            "Asturian",
            "Belarusian",
            "Breton",
            "Catalan",
            "Catalan (Valencian)",
            "Chinese",
            "Danish",
            "Dutch",
            "English",
