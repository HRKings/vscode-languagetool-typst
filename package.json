            "Simple German",
            "Slovak",
            "Slovenian",
            "Spanish",
            "Swedish",
            "Tagalog",
            "Tamil",
            "Ukrainian"
          ]
        },
        "languageToolTypst.languageTool.motherTongue": {
          "type": "string",
          "default": "",
          "description": "A language code of the user's native language, enabling false friends checks for some language pairs.",
          "enum": [
            "",
            "ast-ES",
            "be-BY",
            "br-FR",
            "ca-ES",
            "ca-ES-valencia",
            "zh-CN",
            "da-DK",
            "nl",
            "en",
            "en-AU",
            "en-CA",
            "en-GB",
            "en-NZ",
            "en-ZA",
            "en-US",
            "eo",
            "fr",
            "gl-ES",
            "de",
            "de-AT",
            "de-DE",
            "de-CH",
            "el-GR",
            "it",
            "ja-JP",
            "km-KH",
            "fa",
            "pl-PL",
            "pt",
            "pt-AO",
