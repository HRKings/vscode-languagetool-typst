{
  "name": "vscode-languagetool-typst",
  "displayName": "LanguageTool Typst",
  "version": "0.1.0",
  "description": "LanguageTool grammar, style, and spell checking for Typst documents.",
  "categories": [
    "Linters"
  ],
  "keywords": [
    "checker",
    "grammar",
    "grammar-checker",
    "languagetool",
    "proofread",
    "spell",
    "spelling",
    "typst"
  ],
  "homepage": "https://github.com/HRKings/vscode-languagetool-typst#readme",
  "bugs": {
    "url": "https://github.com/HRKings/vscode-languagetool-typst/issues"
  },
  "license": "Apache-2.0",
  "author": "David L. Day <david@davidlday.com> (https://www.davidlday.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/HRKings/vscode-languagetool-typst"
  },
  "publisher": "HRKings",
  "main": "./dist/extension.js",
  "scripts": {
    "clean": "rm -rf out/* dist/*",
    "vscode:prepublish": "webpack --mode production",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch --info-verbosity verbose",
    "compile": "webpack --mode none",
    "watch": "webpack --mode development --watch --info-verbosity verbose",
    "test-compile": "bun run main-out && tsc -p ./",
    "main-out": "json -I -f package.json -e 'this.main=\"./out/src/extension.js\"'",
    "main-dist": "json -I -f package.json -e 'this.main=\"./dist/extension.js\"'",
    "pretest": "bun run test-compile",
    "test": "node ./out/test/runTest.js && bun run main-dist",
    "lint": "oxlint ./src/",
    "package": "bunx vsce package --no-dependencies"
  },
  "dependencies": {
    "@myriaddreamin/typst-ts-parser": "^0.7.0-rc2",
    "annotatedtext": "^1.2.1",
    "execa": "^9.6.1",
    "glob": "^13.0.6",
    "node-fetch": "^3.3.2",
    "portfinder": "^1.0.38",
    "web-tree-sitter": "^0.25.10"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "@types/vscode": "^1.118.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "json": "^11.0.0",
    "mocha": "^11.7.5",
    "oxlint": "^1.62.0",
    "tree-sitter-cli": "^0.26.8",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1",
    "webpack-license-plugin": "^4.5.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "languageToolTypst.checkDocument",
        "title": "Check Typst Document",
        "category": "LanguageTool Typst"
      },
      {
        "command": "languageToolTypst.clearDocumentDiagnostics",
        "title": "Clear Typst Diagnostics",
        "category": "LanguageTool Typst"
      },
      {
        "command": "languageToolTypst.toggleSuspendLinting",
        "title": "Toggle LanguageTool Typst Linting on/off (temporarily). Linting on demand remains available.",
        "category": "LanguageTool Typst"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "languageToolTypst.checkDocument",
          "when": "editorLangId == typst"
        },
        {
          "command": "languageToolTypst.clearDocumentDiagnostics"
        }
      ],
      "editor/context": [
        {
          "command": "languageToolTypst.checkDocument",
          "title": "LanguageTool Typst: Check Document",
          "when": "editorLangId == typst",
          "group": "LanguageToolTypst"
        },
        {
          "command": "languageToolTypst.clearDocumentDiagnostics",
          "title": "LanguageTool Typst: Clear Document Diagnostics",
          "group": "LanguageToolTypst"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "LanguageTool Typst",
      "properties": {
        "languageToolTypst.diagnosticSeverity": {
          "type": "string",
          "default": "warning",
          "description": "Set the severity level for LanguageTool diagnostics.",
          "enum": [
            "information",
            "warning",
            "error"
          ]
        },
        "languageToolTypst.diagnosticSeverityAuto": {
          "type": "boolean",
          "default": false,
          "description": "Spelling mistakes will be set as Error, while punctuation, grammar and typography mistakes as Warning. Anything else as the configured Diagnostic Severity level (recommended to be set as Information when using this option)."
        },
        "languageToolTypst.ruleSeverityOverrides": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string",
            "enum": [
              "hint",
              "information",
              "warning",
              "error"
            ]
          },
          "markdownDescription": "Map LanguageTool rule IDs to diagnostic severities. Rule overrides take precedence over category overrides and automatic severity. Example: `{ \"FABRIC\": \"hint\", \"MORFOLOGIK_RULE_EN_US\": \"error\" }`."
        },
        "languageToolTypst.categorySeverityOverrides": {
          "type": "object",
          "default": {
            "FALSE_FRIENDS": "hint"
          },
          "additionalProperties": {
            "type": "string",
            "enum": [
              "hint",
              "information",
              "warning",
              "error"
            ]
          },
          "markdownDescription": "Map LanguageTool category IDs to diagnostic severities. These overrides take precedence over automatic severity. Example: `{ \"FALSE_FRIENDS\": \"hint\", \"TYPOGRAPHY\": \"information\" }`."
        },
        "languageToolTypst.hideDiagnosticsOnChange": {
          "type": "boolean",
          "default": false,
          "description": "Hide diagnostic messages on document changes. Most noticable when used with 'Lint on Change'."
        },
        "languageToolTypst.hideRuleIds": {
          "type": "boolean",
          "default": false,
          "description": "Hide Rule IDs in messages."
        },
        "languageToolTypst.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write verbose LanguageTool Typst debug information to the output channel."
        },
        "languageToolTypst.lintOnChange": {
          "type": "boolean",
          "default": false,
          "description": "Lint every time the document changes. Use with caution."
        },
        "languageToolTypst.lintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Lint documents when they're saved."
        },
        "languageToolTypst.lintOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Lint documents when they're opened."
        },
        "languageToolTypst.serviceType": {
          "type": "string",
          "default": "external",
          "description": "What kind of LanguageTool service to use: external (default), public, or managed.",
          "enum": [
            "external",
            "managed",
            "public"
          ],
          "enumDescriptions": [
            "Provide a URL to an external LanguageTool service. Defaults to 'http://localhost:8081'. Specify the URL in 'External: Url'.",
            "Let LanguageTool Typst manage a local service. Specify the classpath or LanguageTool jar file in 'Managed: Class Path'.",
            "Use the public LanguageTool API Service at https://languagetool.org/api."
          ]
        },
        "languageToolTypst.external.url": {
          "type": "string",
          "default": "http://localhost:8081",
          "description": "URL of your LanguageTool server. Defaults to localhost on port 8081."
        },
        "languageToolTypst.external.username": {
          "type": "string",
          "default": "",
          "description": "Set to get Premium API access if you use the languagetool.org api instance: your username/email as used to log in at languagetool.org."
        },
        "languageToolTypst.external.apiKey": {
          "type": "string",
          "default": "",
          "description": "Set to get Premium API access if you use the languagetool.org api instance: your API key."
        },
        "languageToolTypst.managed.classPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Custom classpath for managed server. Separate multiple paths using the native filesystem separator. Supports file globbing via [node-glob](https://github.com/isaacs/node-glob)."
        },
        "languageToolTypst.managed.jarFile": {
          "type": "string",
          "default": "",
          "description": "DEPRECATED. Path to languagetool-server.jar on your local machine."
        },
        "languageToolTypst.managed.portMinimum": {
          "type": "number",
          "minimum": 1024,
          "maximum": 65535,
          "default": 9500,
          "description": "Minimum port number to use for managed service."
        },
        "languageToolTypst.managed.portMaximum": {
          "type": "number",
          "minimum": 1024,
          "maximum": 65535,
          "default": 65535,
          "description": "Minimum port number to use for managed service."
        },
        "languageToolTypst.languageTool.language": {
          "type": "string",
          "default": "auto",
          "description": "A language code like en-US, de-DE, fr, or auto to guess the language automatically (see preferredVariants below). For languages with variants (English, German, Portuguese) spell checking will only be activated when you specify the variant, e.g. en-GB instead of just en.",
          "enum": [
            "auto",
            "ast-ES",
            "be-BY",
            "br-FR",
            "ca-ES",
            "ca-ES-valencia",
            "zh-CN",
            "da-DK",
            "nl",
            "en",
            "en-AU",
            "en-CA",
            "en-GB",
            "en-NZ",
            "en-ZA",
            "en-US",
            "eo",
            "fr",
            "gl-ES",
            "de",
            "de-AT",
            "de-DE",
            "de-CH",
            "el-GR",
            "it",
            "ja-JP",
            "km-KH",
            "fa",
            "pl-PL",
            "pt",
            "pt-AO",
            "pt-BR",
